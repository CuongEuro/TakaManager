# Copy to .env and fill in.
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Cloud (PostgreSQL example):
# DATABASE_URL="postgresql://user:password@host:5432/takamanager?schema=public"

# Auth: secret for signing session cookies. Generate: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Integrations (Phase 2+) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
META_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
TWITTER_ADS_API_KEY=

# --- AI Assistant (Phase 4) ---
ANTHROPIC_API_KEY=
